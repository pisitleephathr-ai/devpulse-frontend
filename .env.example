# Base URL of the DevPulse backend API (no trailing slash).
# Local dev:  http://localhost:4000
# Production: your Railway backend URL, e.g. https://devpulse-backend-production.up.railway.app
NEXT_PUBLIC_API_URL=http://localhost:4000

# Cloudinary is NOT configured on the frontend. The upload flow gets the cloud
# name (and the signed params) from the backend's signature response, so no
# CLOUDINARY_* / NEXT_PUBLIC_CLOUDINARY_* variable is needed here. The Cloudinary
# API secret must never appear in any frontend env var.
